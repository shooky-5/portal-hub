interface IconProps {
  path: string | string[];
  size?: number;
  color?: string;
  style?: React.CSSProperties;
}

const Icon: React.FC<IconProps> = ({ path, size = 16, color = 'currentColor', style: s = {} }) => (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke={color}
    strokeWidth="1.5"
    strokeLinecap="round"
    strokeLinejoin="round"
    aria-hidden="true"
    style={{ flexShrink: 0, ...s }}
  >
    {Array.isArray(path) ? path.map((d, i) => <path key={i} d={d} />) : <path d={path} />}
  </svg>
);

// ── THEME TOGGLE ─────────────────────────────────────────────────────────
function ThemeToggle({ onDark = false }: { onDark?: boolean }) {
  const { isDark, toggle } = useTheme();
  const [hov, setHov] = useState(false);
  const fg = onDark ? (hov ? '#F8FAFC' : 'rgba(255,255,255,0.5)') : hov ? '#1A2B42' : '#5A7490';
  const border = onDark ? (hov ? 'rgba(255,255,255,0.35)' : 'rgba(255,255,255,0.15)') : hov ? '#2E75B6' : '#C0CEDF';
  const bg = onDark ? (hov ? 'rgba(255,255,255,0.08)' : 'transparent') : hov ? '#EBF2FB' : 'transparent';

  return (
    <button
      onClick={toggle}
      aria-label={isDark ? 'Switch to light mode' : 'Switch to dark mode'}
      onMouseEnter={() => setHov(true)}
      onMouseLeave={() => setHov(false)}
      style={{
        display: 'flex',
        alignItems: 'center',
        gap: 6,
        background: bg,
        border: `1px solid ${border}`,
        borderRadius: 20,
        padding: '5px 12px',
        cursor: 'pointer',
        fontFamily: "'Outfit',sans-serif",
        fontSize: 11,
        fontWeight: 500,
        letterSpacing: '0.08em',
        color: fg,
        transition: 'all 200ms ease-in-out',
      }}
    >
      <Icon path={isDark ? ICONS.sun : ICONS.moon} size={13} color="currentColor" />
      {isDark ? 'Light' : 'Dark'}
    </button>
  );
}

// ── LOGO ─────────────────────────────────────────────────────────────────
function LogoMark({
  height = 44,
  stroke = '#60A5FA',
  fill = 'rgba(96,165,250,0.07)',
  ring = 'rgba(96,165,250,0.18)',
}: {
  height?: number;
  stroke?: string;
  fill?: string;
  ring?: string;
}) {
  const w = height * (30 / 40);
  return (
    <svg width={w} height={height} viewBox="0 0 30 40" fill="none" aria-hidden="true">
      <path
        d="M15 1.5L28.5 6.5V24C28.5 31.5 15 38.5 15 38.5C15 38.5 1.5 31.5 1.5 24V6.5L15 1.5Z"
        fill={fill}
        stroke={stroke}
        strokeWidth="1.4"
        strokeLinejoin="round"
      />
      <path
        d="M15 5.5L25 9.5V23C25 28.5 15 34 15 34C15 34 5 28.5 5 23V9.5L15 5.5Z"
        fill="none"
        stroke={ring}
        strokeWidth="0.8"
        strokeLinejoin="round"
      />
      <line x1="8.5" y1="15" x2="21.5" y2="15" stroke={stroke} strokeWidth="2" strokeLinecap="round" />
      <line x1="10.5" y1="21" x2="19.5" y2="21" stroke={stroke} strokeWidth="2" strokeLinecap="round" opacity="0.65" />
      <line x1="13" y1="27" x2="17" y2="27" stroke={stroke} strokeWidth="2" strokeLinecap="round" opacity="0.35" />
    </svg>
  );
}

function Logo({ variant = 'stacked', markHeight = 44 }: { variant?: string; markHeight?: number }) {
  const { T } = useTheme();
  if (variant === 'stacked')
    return (
      <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', gap: 14 }}>
        <LogoMark height={markHeight} stroke={T.logoStroke} fill={T.logoFill} ring={T.logoRing} />
        <div style={{ textAlign: 'center' }}>
          <div
            style={{
              fontSize: 20,
              fontWeight: 700,
              letterSpacing: '0.12em',
              textTransform: 'uppercase',
              color: '#F8FAFC',
              lineHeight: 1,
            }}
          >
            Analytic Armory
          </div>
          <div
            style={{
              fontSize: 10,
              fontWeight: 500,
              letterSpacing: '0.26em',
              textTransform: 'uppercase',
              color: 'rgba(255,255,255,0.42)',
              marginTop: 6,
            }}
          >
            Decision Intelligence Platform
          </div>
        </div>
        <div
          style={{
            width: 36,
            height: 1.5,
            background: T.logoStroke,
            borderRadius: 1,
            opacity: 0.6,
          }}
        />
      </div>
    );

  return (
    <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
      <LogoMark height={markHeight} stroke={T.logoStroke} fill={T.logoFill} ring={T.logoRing} />
      <div>
        <div
          style={{
            fontSize: 13,
            fontWeight: 700,
            letterSpacing: '0.1em',
            textTransform: 'uppercase',
            color: '#F8FAFC',
            lineHeight: 1.2,
          }}
        >
          Analytic
          <br />
          Armory
        </div>
        <div
          style={{
            fontSize: 9,
            fontWeight: 500,
            letterSpacing: '0.18em',
            textTransform: 'uppercase',
            color: 'rgba(255,255,255,0.38)',
            marginTop: 4,
          }}
        >
          Decision Intelligence
        </div>
      </div>
    </div>
  );
}

