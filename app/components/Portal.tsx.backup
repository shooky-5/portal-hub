// ── SHARED COMPONENTS ────────────────────────────────────────────────────
interface PageHeaderProps {
  eyebrow: string;
  title: string;
  subtitle?: string;
}

function PageHeader({ eyebrow, title, subtitle }: PageHeaderProps) {
  const { T } = useTheme();
  return (
    <div style={{ marginBottom: 36 }}>
      <div
        style={{
          fontSize: 11,
          fontWeight: 500,
          letterSpacing: '0.2em',
          textTransform: 'uppercase',
          color: T.accent,
          marginBottom: 10,
        }}
      >
        {eyebrow}
      </div>
      <h1
        style={{
          fontFamily: "'Outfit',sans-serif",
          fontSize: 28,
          fontWeight: 700,
          color: T.textPri,
          letterSpacing: '-0.01em',
          marginBottom: subtitle ? 8 : 0,
        }}
      >
        {title}
      </h1>
      {subtitle && (
        <p
          style={{
            fontFamily: "'Newsreader',serif",
            fontSize: 15,
            fontStyle: 'italic',
            color: T.textSec,
            lineHeight: 1.65,
            maxWidth: 540,
          }}
        >
          {subtitle}
        </p>
      )}
      <div
        style={{
          marginTop: 24,
          height: 1,
          background: `linear-gradient(to right,${T.border},transparent)`,
        }}
      />
    </div>
  );
}

interface AppCardProps {
  app: (typeof APPS)[0];
  delay: number;
}

function AppCard({ app, delay }: AppCardProps) {
  const { T } = useTheme();
  const [hov, setHov] = useState(false);
  const [vis, setVis] = useState(false);

  useEffect(() => {
    const t = setTimeout(() => setVis(true), delay);
    return () => clearTimeout(t);
  }, [delay]);

  const handleClick = () => {
    if (app.url && app.url !== '#') {
      window.open(app.url, '_blank');
    }
  };

  return (
    <div
      role="button"
      tabIndex={0}
      aria-label={`Launch ${app.name}: ${app.full}`}
      onClick={handleClick}
      onMouseEnter={() => setHov(true)}
      onMouseLeave={() => setHov(false)}
      onFocus={() => setHov(true)}
      onBlur={() => setHov(false)}
      style={{
        background: hov ? T.bgElev : T.bgSurface,
        border: `1px solid ${hov ? app.color + '55' : T.border}`,
        borderRadius: 8,
        padding: '24px',
        cursor: 'pointer',
        transition: 'background 200ms ease-in-out,border-color 200ms ease-in-out,box-shadow 200ms ease-in-out',
        position: 'relative',
        overflow: 'hidden',
        opacity: vis ? 1 : 0,
        transform: vis ? 'translateY(0)' : 'translateY(10px)',
        boxShadow: hov ? `0 4px 20px ${app.color}18` : 'none',
        outline: 'none',
      }}
    >
      <div
        style={{
          position: 'absolute',
          top: 0,
          left: 0,
          right: 0,
          height: 3,
          background: app.color,
          borderRadius: '8px 8px 0 0',
          opacity: hov ? 1 : 0.4,
          transition: 'opacity 200ms ease-in-out',
        }}
      />
      <div
        style={{
          display: 'flex',
          justifyContent: 'space-between',
          alignItems: 'flex-start',
          marginBottom: 18,
        }}
      >
        <div
          style={{
            width: 42,
            height: 42,
            background: app.color + '18',
            border: `1px solid ${app.color}30`,
            borderRadius: 4,
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
          }}
        >
          <Icon path={ICONS[app.icon]} size={20} color={app.color} />
        </div>
        <div
          style={{
            display: 'flex',
            alignItems: 'center',
            gap: 5,
            fontSize: 11,
            fontWeight: 500,
            color: T.success,
            letterSpacing: '0.1em',
            textTransform: 'uppercase',
          }}
        >
          <svg width="6" height="6" viewBox="0 0 24 24" fill={T.success} aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
          </svg>
          ACTIVE
        </div>
      </div>
      <div
        style={{
          fontFamily: "'Outfit',sans-serif",
          fontSize: 16,
          fontWeight: 600,
          color: T.textPri,
          marginBottom: 3,
        }}
      >
        {app.name}
      </div>
      <div
        style={{
          fontSize: 11,
          fontWeight: 500,
          letterSpacing: '0.08em',
          textTransform: 'uppercase',
          color: app.color,
          marginBottom: 12,
          opacity: 0.9,
        }}
      >
        {app.full}
      </div>
      <div
        style={{
          fontFamily: "'Newsreader',serif",
          fontSize: 14,
          lineHeight: 1.65,
          color: T.textSec,
          marginBottom: 18,
        }}
      >
        {app.desc}
      </div>
      <div
        style={{
          display: 'flex',
          justifyContent: 'space-between',
          alignItems: 'center',
          paddingTop: 14,
          borderTop: `1px solid ${T.border}`,
        }}
      >
        <span style={{ fontSize: 12, color: T.textSec }}>Last run: {app.lastRun}</span>
        <div
          style={{
            display: 'flex',
            alignItems: 'center',
            gap: 4,
            fontSize: 11,
            fontWeight: 600,
            letterSpacing: '0.1em',
            textTransform: 'uppercase',
            color: hov ? app.color : T.textSec,
            transition: 'color 200ms ease-in-out',
          }}
        >
          Launch
          <Icon
            path={ICONS.chevron}
            size={14}
            color="currentColor"
            style={{
              transform: hov ? 'translateX(3px)' : 'translateX(0)',
              transition: 'transform 200ms ease-in-out',
            }}
          />
        </div>
      </div>
    </div>
  );
}

// ── VIEWS ────────────────────────────────────────────────────────────────
interface ArmoryViewProps {
  userName: string;
}

function ArmoryView({ userName }: ArmoryViewProps) {
  const { T, isDark } = useTheme();
  const h = new Date().getHours();
  const greeting = h < 12 ? 'Good morning' : h < 17 ? 'Good afternoon' : 'Good evening';
  const name = userName.charAt(0) + userName.slice(1).toLowerCase().replace('.', ' ');
  const pAccents = P_ACCENTS[isDark ? 'dark' : 'light'];

  return (
    <div style={{ padding: '40px 40px 64px' }}>
      <PageHeader
        eyebrow="Mission Applications"
        title={`${greeting}, ${name}.`}
        subtitle="Select a mission tool to begin structured analysis."
      />
      <div style={{ marginBottom: 32, display: 'flex', alignItems: 'center', gap: 10 }}>
        <div
          style={{
            width: 3,
            height: 16,
            background: T.accent,
            borderRadius: 2,
            flexShrink: 0,
          }}
        />
        <span
          style={{
            fontFamily: "'Newsreader',serif",
            fontSize: 15,
            fontStyle: 'italic',
            color: T.textSec,
          }}
        >
          Built on the premise that AI should challenge, not confirm.
        </span>
      </div>
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3,1fr)', gap: 18 }}>
        {APPS.map((a, i) => (
          <AppCard key={a.id} app={a} delay={60 + i * 70} />
        ))}
      </div>
      <div
        style={{
          marginTop: 48,
          textAlign: 'center',
          fontFamily: "'Newsreader',serif",
          fontSize: 17,
          fontStyle: 'italic',
          color: T.textPri,
          opacity: 0.6,
        }}
      >
        If the mission requires a tool that does not exist here — we build it.
      </div>

      {/* Platform Principles */}
      <div
        style={{
          marginTop: 52,
          paddingTop: 32,
          borderTop: `1px solid ${T.border}`,
        }}
      >
        <div
          style={{
            fontSize: 11,
            fontWeight: 500,
            letterSpacing: '0.2em',
            textTransform: 'uppercase',
            color: T.textSec,
            marginBottom: 20,
            textAlign: 'center',
          }}
        >
          Platform Principles
        </div>
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(5,1fr)', gap: 12 }}>
          {PRINCIPLES.map((p, i) => {
            const col = pAccents[i];
            return (
              <div
                key={i}
                style={{
                  background: isDark
                    ? `linear-gradient(150deg,${col}14 0%,${T.bgSurface} 60%)`
                    : `linear-gradient(150deg,${col}0E 0%,${T.bgSurface} 60%)`,
                  border: `1px solid ${col}30`,
                  borderTop: `3px solid ${col}`,
                  borderRadius: 8,
                  padding: '18px 14px',
                  position: 'relative',
                  overflow: 'hidden',
                }}
              >
                <div
                  style={{
                    position: 'absolute',
                    top: -12,
                    right: -12,
                    width: 52,
                    height: 52,
                    borderRadius: '50%',
                    background: col,
                    opacity: isDark ? 0.07 : 0.04,
                    pointerEvents: 'none',
                  }}
                />
                <Icon path={ICONS[p.icon]} size={18} color={col} style={{ marginBottom: 10 }} />
                <div
                  style={{
                    fontFamily: "'Outfit',sans-serif",
                    fontSize: 12,
                    fontWeight: 700,
                    color: col,
                    marginBottom: 6,
                    letterSpacing: '0.04em',
                    textTransform: 'uppercase',
                  }}
                >
                  {p.label}
                </div>
                <div
                  style={{
                    fontFamily: "'Newsreader',serif",
                    fontSize: 12,
                    fontStyle: 'italic',
                    color: T.textSec,
                    lineHeight: 1.55,
                  }}
                >
                  {p.note}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  );
}

function SessionsView() {
  const { T } = useTheme();
  return (
    <div style={{ padding: '40px 40px 64px' }}>
      <PageHeader
        eyebrow="Audit Trail"
        title="Recent Sessions"
        subtitle="All analytical sessions are logged. Conclusions are traceable to their reasoning chain and source data."
      />
      <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>
        {SESSIONS.map((s, i) => (
          <div
            key={i}
            role="button"
            tabIndex={0}
            aria-label={`Open session: ${s.topic}`}
            style={{
              background: T.bgSurface,
              border: `1px solid ${T.border}`,
              borderRadius: 8,
              padding: '18px 24px',
              display: 'flex',
              alignItems: 'center',
              gap: 18,
              cursor: 'pointer',
              outline: 'none',
              transition: 'background 200ms ease-in-out,border-color 200ms ease-in-out',
            }}
            onMouseEnter={(e) => {
              (e.currentTarget as HTMLDivElement).style.background = T.bgElev;
              (e.currentTarget as HTMLDivElement).style.borderColor = s.pillar + '55';
            }}
            onMouseLeave={(e) => {
              (e.currentTarget as HTMLDivElement).style.background = T.bgSurface;
              (e.currentTarget as HTMLDivElement).style.borderColor = T.border;
            }}
          >
            <div
              style={{
                width: 3,
                height: 40,
                background: s.pillar,
                borderRadius: 2,
                flexShrink: 0,
              }}
            />
            <div style={{ flex: 1, minWidth: 0 }}>
              <div
                style={{
                  fontFamily: "'Outfit',sans-serif",
                  fontSize: 13,
                  fontWeight: 600,
                  color: T.textPri,
                  marginBottom: 3,
                  whiteSpace: 'nowrap',
                  overflow: 'hidden',
                  textOverflow: 'ellipsis',
                }}
              >
                {s.topic}
              </div>
              <div style={{ fontSize: 11, fontWeight: 500, color: T.textSec }}>{s.app}</div>
            </div>
            <div style={{ textAlign: 'right', flexShrink: 0 }}>
              <div style={{ fontSize: 12, color: T.textSec, marginBottom: 2 }}>{s.user}</div>
              <div style={{ fontSize: 11, color: T.textSec, opacity: 0.65 }}>{s.time}</div>
            </div>
            <Icon path={ICONS.chevron} size={16} color={T.textSec} />
          </div>
        ))}
      </div>
    </div>
  );
}

function StatusView() {
  const { T } = useTheme();
  const cfg = {
    operational: { color: T.success, label: 'Operational', icon: 'check' },
    degraded: { color: T.warning, label: 'Degraded', icon: 'triangle' },
    outage: { color: T.error, label: 'Outage', icon: 'info' },
  };
  const overall = STATUS_ITEMS.some((s) => s.state === 'outage')
    ? 'outage'
    : STATUS_ITEMS.some((s) => s.state === 'degraded')
      ? 'degraded'
      : 'operational';
  const oc = cfg[overall as keyof typeof cfg];

  return (
    <div style={{ padding: '40px 40px 64px' }}>
      <PageHeader
        eyebrow="Infrastructure"
        title="Platform Status"
        subtitle="Real-time status of all platform components. Confidence levels are always visible."
      />
      <div
        style={{
          background: T.bgSurface,
          border: `1px solid ${oc.color}50`,
          borderRadius: 8,
          padding: '20px 24px',
          marginBottom: 20,
          display: 'flex',
          alignItems: 'center',
          gap: 14,
        }}
      >
        <Icon path={ICONS[oc.icon]} size={20} color={oc.color} />
        <div>
          <div
            style={{
              fontFamily: "'Outfit',sans-serif",
              fontSize: 14,
              fontWeight: 600,
              color: T.textPri,
              marginBottom: 2,
            }}
          >
            Overall System Health — <span style={{ color: oc.color }}>{oc.label}</span>
          </div>
          <div style={{ fontSize: 12, color: T.textSec }}>
            {STATUS_ITEMS.filter((s) => s.state === 'operational').length} of {STATUS_ITEMS.length} components fully
            operational
          </div>
        </div>
      </div>
      <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>
        {STATUS_ITEMS.map((item, i) => {
          const c = cfg[item.state as keyof typeof cfg];
          return (
            <div
              key={i}
              style={{
                background: T.bgSurface,
                border: `1px solid ${T.border}`,
                borderRadius: 8,
                padding: '18px 24px',
                display: 'flex',
                alignItems: 'center',
                gap: 14,
              }}
            >
              <Icon path={ICONS[c.icon]} size={16} color={c.color} />
              <div style={{ flex: 1 }}>
                <div
                  style={{
                    fontFamily: "'Outfit',sans-serif",
                    fontSize: 13,
                    fontWeight: 600,
                    color: T.textPri,
                    marginBottom: 2,
                  }}
                >
                  {item.label}
                </div>
                <div style={{ fontSize: 12, color: T.textSec }}>{item.note}</div>
              </div>
              <div
                style={{
                  fontSize: 11,
                  fontWeight: 600,
                  letterSpacing: '0.1em',
                  textTransform: 'uppercase',
                  color: c.color,
                  flexShrink: 0,
                }}
              >
                {c.label}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  );
}

interface SettingsViewProps {
  userName: string;
}

function SettingsView({ userName }: SettingsViewProps) {
  const { T } = useTheme();
  const fields = [
    { label: 'Display Name', value: userName, id: 's-name' },
    { label: 'Organisation Unit', value: 'Strategic Intel', id: 's-org' },
    { label: 'Classification Level', value: 'UNCLASSIFIED', id: 's-class' },
    { label: 'Notification Email', value: 'analyst@armory.gov', id: 's-email' },
  ];

  return (
    <div style={{ padding: '40px 40px 64px' }}>
      <PageHeader
        eyebrow="Configuration"
        title="Settings"
        subtitle="Platform configuration for your analyst profile and session preferences."
      />
      <div
        style={{
          background: T.bgSurface,
          border: `1px solid ${T.border}`,
          borderRadius: 8,
          padding: '28px',
          maxWidth: 520,
        }}
      >
        <div
          style={{
            fontSize: 11,
            fontWeight: 600,
            letterSpacing: '0.15em',
            textTransform: 'uppercase',
            color: T.textSec,
            marginBottom: 24,
          }}
        >
          Analyst Profile
        </div>
        <div style={{ display: 'flex', flexDirection: 'column', gap: 20 }}>
          {fields.map((f) => (
            <div key={f.id}>
              <label
                htmlFor={f.id}
                style={{
                  display: 'block',
                  fontSize: 11,
                  fontWeight: 600,
                  letterSpacing: '0.1em',
                  textTransform: 'uppercase',
                  color: T.textSec,
                  marginBottom: 8,
                }}
              >
                {f.label}
              </label>
              <input
                id={f.id}
                type="text"
                defaultValue={f.value}
                style={{
                  width: '100%',
                  background: T.inputBg,
                  border: `1px solid ${T.border}`,
                  borderRadius: 4,
                  padding: '11px 14px',
                  color: T.textPri,
                  fontSize: 14,
                  fontFamily: "'Outfit',sans-serif",
                  outline: 'none',
                }}
                onFocus={(e) => {
                  e.target.style.outline = `2px solid ${T.accent}`;
                  e.target.style.outlineOffset = '2px';
                }}
                onBlur={(e) => (e.target.style.outline = 'none')}
              />
            </div>
          ))}
        </div>
        <button
          style={{
            marginTop: 28,
            padding: '11px 24px',
            background: T.accent,
            border: 'none',
            borderRadius: 4,
            color: '#FFFFFF',
            fontSize: 12,
            fontWeight: 700,
            letterSpacing: '0.12em',
            textTransform: 'uppercase',
            cursor: 'pointer',
            fontFamily: "'Outfit',sans-serif",
            transition: 'background 200ms ease-in-out',
          }}
          onMouseEnter={(e) => ((e.currentTarget as HTMLButtonElement).style.background = T.accentHov)}
          onMouseLeave={(e) => ((e.currentTarget as HTMLButtonElement).style.background = T.accent)}
        >
          Save Changes
        </button>
      </div>
    </div>
  );
}

// ── SIDEBAR ──────────────────────────────────────────────────────────────
interface SidebarProps {
  active: string;
  onNav: (id: string) => void;
  userName: string;
  onLogout: () => void;
}

function Sidebar({ active, onNav, userName, onLogout }: SidebarProps) {
  const { T } = useTheme();
  const navActive = '#F8FAFC';
  const navInactive = 'rgba(255,255,255,0.48)';
  const navActiveBg = 'rgba(255,255,255,0.09)';
  const navHovBg = 'rgba(255,255,255,0.05)';
  const sideBorder = 'rgba(255,255,255,0.09)';

  return (
    <aside
      aria-label="Primary navigation"
      style={{
        width: 220,
        flexShrink: 0,
        background: T.sidebarBg,
        borderRight: `1px solid ${sideBorder}`,
        display: 'flex',
        flexDirection: 'column',
        height: '100vh',
        position: 'sticky',
        top: 0,
        overflowY: 'auto',
      }}
    >
      <div style={{ padding: '18px 16px 16px', borderBottom: `1px solid ${sideBorder}` }}>
        <Logo variant="horizontal" markHeight={34} />
      </div>
      <nav style={{ flex: 1, padding: '12px 0' }}>
        {NAV.map((n) => {
          const isActive = active === n.id;
          return (
            <button
              key={n.id}
              onClick={() => onNav(n.id)}
              aria-current={isActive ? 'page' : undefined}
              style={{
                width: '100%',
                display: 'flex',
                alignItems: 'center',
                gap: 11,
                padding: '11px 20px',
                background: isActive ? navActiveBg : 'transparent',
                border: 'none',
                borderLeft: `2px solid ${isActive ? '#60A5FA' : 'transparent'}`,
                color: isActive ? navActive : navInactive,
                fontSize: 13,
                fontWeight: isActive ? 600 : 400,
                letterSpacing: '0.03em',
                cursor: 'pointer',
                textAlign: 'left',
                fontFamily: "'Outfit',sans-serif",
                transition: 'background 200ms ease-in-out,color 200ms ease-in-out',
              }}
              onMouseEnter={(e) => {
                if (!isActive) {
                  (e.currentTarget as HTMLButtonElement).style.background = navHovBg;
                  (e.currentTarget as HTMLButtonElement).style.color = navActive;
                }
              }}
              onMouseLeave={(e) => {
                if (!isActive) {
                  (e.currentTarget as HTMLButtonElement).style.background = 'transparent';
                  (e.currentTarget as HTMLButtonElement).style.color = navInactive;
                }
              }}
            >
              <Icon path={ICONS[n.icon]} size={16} color="currentColor" />
              {n.label}
            </button>
          );
        })}
      </nav>
      <div style={{ padding: '16px 20px', borderTop: `1px solid ${sideBorder}` }}>
        <div
          style={{
            display: 'flex',
            alignItems: 'center',
            gap: 6,
            fontSize: 11,
            fontWeight: 500,
            color: '#10B981',
            letterSpacing: '0.1em',
            textTransform: 'uppercase',
            marginBottom: 10,
          }}
        >
          <svg width="6" height="6" viewBox="0 0 24 24" fill="#10B981" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
          </svg>
          Session Active
        </div>
        <div
          style={{
            fontSize: 12,
            fontWeight: 600,
            color: '#F8FAFC',
            letterSpacing: '0.06em',
            textTransform: 'uppercase',
            marginBottom: 12,
          }}
        >
          {userName}
        </div>
        <div style={{ marginBottom: 10 }}>
          <ThemeToggle onDark={true} />
        </div>
        <button
          onClick={onLogout}
          aria-label="Log out"
          style={{
            display: 'flex',
            alignItems: 'center',
            gap: 7,
            background: 'transparent',
            border: '1px solid rgba(255,255,255,0.14)',
            borderRadius: 4,
            padding: '7px 12px',
            width: '100%',
            fontSize: 11,
            fontWeight: 600,
            letterSpacing: '0.1em',
            textTransform: 'uppercase',
            color: 'rgba(255,255,255,0.42)',
            cursor: 'pointer',
            fontFamily: "'Outfit',sans-serif",
            transition: 'all 200ms ease-in-out',
          }}
          onMouseEnter={(e) => {
            (e.currentTarget as HTMLButtonElement).style.borderColor = 'rgba(255,255,255,0.38)';
            (e.currentTarget as HTMLButtonElement).style.color = '#F8FAFC';
          }}
          onMouseLeave={(e) => {
            (e.currentTarget as HTMLButtonElement).style.borderColor = 'rgba(255,255,255,0.14)';
            (e.currentTarget as HTMLButtonElement).style.color = 'rgba(255,255,255,0.42)';
          }}
        >
          <Icon path={ICONS.logout} size={14} color="currentColor" />
          Log Out
        </button>
      </div>
    </aside>
  );
}

// ── LOGIN ────────────────────────────────────────────────────────────────
interface LoginProps {
  onLogin: (name: string) => void;
}

function Login({ onLogin }: LoginProps) {
  const { T, isDark } = useTheme();
  const [user, setUser] = useState('');
  const [pass, setPass] = useState('');
  const [loading, setLoad] = useState(false);
  const [error, setError] = useState('');
  const [vis, setVis] = useState(false);

  useEffect(() => {
    setTimeout(() => setVis(true), 60);
  }, []);

  const submit = (demo?: string) => {
    const u = demo || user;
    if (!demo && (!user || !pass)) {
      setError('Credentials required.');
      return;
    }
    setError('');
    setLoad(true);
    setTimeout(() => {
      setLoad(false);
      onLogin(u);
    }, demo ? 600 : 1400);
  };

  const iStyle: React.CSSProperties = {
    width: '100%',
    background: T.inputBg,
    border: `1px solid ${T.border}`,
    borderRadius: 4,
    padding: '11px 14px',
    color: T.textPri,
    fontSize: 14,
    fontFamily: "'Outfit',sans-serif",
    outline: 'none',
  };

  const lStyle: React.CSSProperties = {
    display: 'block',
    fontSize: 11,
    fontWeight: 600,
    letterSpacing: '0.1em',
    textTransform: 'uppercase',
    color: T.textSec,
    marginBottom: 8,
  };

  return (
    <div
      style={{
        minHeight: '100vh',
        background: T.bgPage,
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        fontFamily: "'Outfit',sans-serif",
        position: 'relative',
      }}
    >
      {/* Toggle top-right */}
      <div style={{ position: 'absolute', top: 20, right: 24 }}>
        <ThemeToggle onDark={isDark} />
      </div>

      <div
        style={{
          width: '100%',
          maxWidth: 400,
          padding: '0 24px',
          opacity: vis ? 1 : 0,
          transform: vis ? 'translateY(0)' : 'translateY(20px)',
          transition: 'opacity 280ms ease-out,transform 280ms ease-out',
        }}
      >
        {/* Logo panel — always navy bg so white mark stays legible */}
        <div style={{ background: '#1F3864', borderRadius: '8px 8px 0 0', padding: '32px 28px 24px', display: 'flex', justifyContent: 'center' }}>
          <Logo variant="stacked" markHeight={52} />
        </div>

        {/* Auth card */}
        <div
          style={{
            background: T.bgSurface,
            border: `1px solid ${T.border}`,
            borderTop: 'none',
            borderRadius: '0 0 8px 8px',
            padding: '32px 28px',
          }}
        >
          <div
            style={{
              fontSize: 11,
              fontWeight: 600,
              letterSpacing: '0.18em',
              textTransform: 'uppercase',
              color: T.textSec,
              marginBottom: 28,
            }}
          >
            Secure Access
          </div>

          <div style={{ marginBottom: 20 }}>
            <label htmlFor="uid" style={lStyle}>
              User ID *
            </label>
            <input
              id="uid"
              type="text"
              value={user}
              aria-required="true"
              onChange={(e) => setUser(e.target.value)}
              onKeyDown={(e) => e.key === 'Enter' && submit()}
              placeholder="analyst.id"
              style={iStyle}
              onFocus={(e) => {
                e.target.style.outline = `2px solid ${T.accent}`;
                e.target.style.outlineOffset = '2px';
              }}
              onBlur={(e) => (e.target.style.outline = 'none')}
            />
          </div>

          <div style={{ marginBottom: 28 }}>
            <label htmlFor="pw" style={lStyle}>
              Passphrase *
            </label>
            <input
              id="pw"
              type="password"
              value={pass}
              aria-required="true"
              onChange={(e) => setPass(e.target.value)}
              onKeyDown={(e) => e.key === 'Enter' && submit()}
              placeholder="••••••••••••"
              style={iStyle}
              onFocus={(e) => {
                e.target.style.outline = `2px solid ${T.accent}`;
                e.target.style.outlineOffset = '2px';
              }}
              onBlur={(e) => (e.target.style.outline = 'none')}
            />
          </div>

          {error && (
            <div
              role="alert"
              style={{
                fontSize: 12,
                color: T.error,
                marginBottom: 16,
                display: 'flex',
                alignItems: 'center',
                gap: 6,
              }}
            >
              <svg width="8" height="8" viewBox="0 0 24 24" fill={T.error} aria-hidden="true">
                <circle cx="12" cy="12" r="10" />
              </svg>
              {error}
            </div>
          )}

          <button
            onClick={() => submit()}
            disabled={loading}
            style={{
              width: '100%',
              padding: '13px',
              background: loading ? T.bgElev : T.accent,
              border: 'none',
              borderRadius: 4,
              color: loading ? T.textSec : '#FFFFFF',
              fontSize: 13,
              fontWeight: 700,
              letterSpacing: '0.15em',
              textTransform: 'uppercase',
              cursor: loading ? 'not-allowed' : 'pointer',
              fontFamily: "'Outfit',sans-serif",
              transition: 'background 200ms ease-in-out,color 200ms ease-in-out',
            }}
          >
            {loading ? 'AUTHENTICATING…' : 'ENTER THE ARMORY'}
          </button>

          <div
            style={{
              marginTop: 20,
              paddingTop: 20,
              borderTop: `1px solid ${T.border}`,
              textAlign: 'center',
            }}
          >
            <div
              style={{
                fontSize: 11,
                color: T.textSec,
                marginBottom: 10,
                letterSpacing: '0.05em',
              }}
            >
              Design preview — skip authentication
            </div>
            <button
              onClick={() => submit('DEMO.ANALYST')}
              style={{
                background: 'transparent',
                border: `1px solid ${T.border}`,
                borderRadius: 4,
                padding: '9px 20px',
                fontSize: 11,
                fontWeight: 600,
                letterSpacing: '0.12em',
                textTransform: 'uppercase',
                color: T.textSec,
                cursor: 'pointer',
                fontFamily: "'Outfit',sans-serif",
                transition: 'border-color 200ms ease-in-out,color 200ms ease-in-out',
              }}
              onMouseEnter={(e) => {
                (e.currentTarget as HTMLButtonElement).style.borderColor = T.accent;
                (e.currentTarget as HTMLButtonElement).style.color = T.accent;
              }}
              onMouseLeave={(e) => {
                (e.currentTarget as HTMLButtonElement).style.borderColor = T.border;
                (e.currentTarget as HTMLButtonElement).style.color = T.textSec;
              }}
            >
              View Portal →
            </button>
          </div>
        </div>

        <div
          style={{
            textAlign: 'center',
            marginTop: 20,
            fontSize: 11,
            color: T.textSec,
            letterSpacing: '0.08em',
          }}
        >
          Restricted access. All sessions are logged.
        </div>
      </div>
    </div>
  );
}

// ── PORTAL SHELL ─────────────────────────────────────────────────────────
interface PortalShellProps {
  userName: string;
  onLogout: () => void;
}

function PortalShell({ userName, onLogout }: PortalShellProps) {
  const { T } = useTheme();
  const [activeNav, setActiveNav] = useState('armory');

  const views: { [key: string]: ReactNode } = {
    armory: <ArmoryView userName={userName} />,
    sessions: <SessionsView />,
    status: <StatusView />,
    settings: <SettingsView userName={userName} />,
  };

  return (
    <div
      style={{
        display: 'flex',
        minHeight: '100vh',
        background: T.bgPage,
        fontFamily: "'Outfit',sans-serif",
      }}
    >
      <Sidebar active={activeNav} onNav={setActiveNav} userName={userName} onLogout={onLogout} />
      <div
        style={{
          flex: 1,
          overflowY: 'auto',
          minWidth: 0,
          display: 'flex',
          flexDirection: 'column',
        }}
      >
        <header
          style={{
            position: 'sticky',
            top: 0,
            zIndex: 50,
            background: T.headerBg + 'F0',
            backdropFilter: 'blur(12px)',
            borderBottom: `1px solid ${T.border}`,
            padding: '0 40px',
            height: 50,
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'flex-end',
            gap: 20,
          }}
        >
          {[
            new Date().toLocaleDateString('en-US', {
              weekday: 'short',
              month: 'short',
              day: 'numeric',
              year: 'numeric',
            }),
            new Date().toLocaleTimeString('en-US', {
              hour: '2-digit',
              minute: '2-digit',
            }) + ' LOCAL',
            'UNCLASSIFIED',
          ].map((item, i) => (
            <span
              key={i}
              style={{
                fontSize: 11,
                fontWeight: 500,
                color: T.textSec,
                letterSpacing: '0.08em',
              }}
            >
              {item}
            </span>
          ))}
        </header>
        <main style={{ flex: 1 }}>{views[activeNav]}</main>
      </div>
    </div>
  );
}

// ── APP ROOT ─────────────────────────────────────────────────────────────
export function PortalApp() {
  const [loggedIn, setLoggedIn] = useState(false);
  const [userName, setUserName] = useState('');
  const [isDark, setIsDark] = useState(false);

  const T = isDark ? THEMES.dark : THEMES.light;
  const toggle = () => setIsDark((d) => !d);

  return (
    <ThemeCtx.Provider value={{ T, isDark, toggle }}>
      {loggedIn ? (
        <PortalShell
          userName={userName.toUpperCase()}
          onLogout={() => {
            setLoggedIn(false);
            setUserName('');
          }}
        />
      ) : (
        <Login
          onLogin={(name) => {
            setUserName(name);
            setLoggedIn(true);
          }}
        />
      )}
    </ThemeCtx.Provider>
  );
}
